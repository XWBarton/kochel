POSTGRES_USER=kochel
POSTGRES_PASSWORD=changeme
POSTGRES_DB=kochel

# Host path to your music library. Mounted read-write into the app container —
# streaming/scanning only ever read, but the browser upload feature writes
# new files here (see backend/app/ingest/upload.py).
MUSIC_LIBRARY_PATH=./dev-library

# Host path where composer profile pictures are stored (uploaded via the
# composer edit UI). Mounted read-write into the app container.
COMPOSER_IMAGES_PATH=./dev-composer-images

APP_PORT=8000
CORS_ORIGINS=*
WEB_PORT=3000
